{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artifact",
  "type": "object",
  "required": [
    "id",
    "projectId",
    "kind",
    "title",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "projectId": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "authorityState": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "hash": {
      "type": "string"
    }
  }
}